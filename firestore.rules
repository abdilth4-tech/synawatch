rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function ownsResource() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    function ownsNewResource() {
      return isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // ===== USERS =====
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read, write: if isAdmin();

      match /{sub=**} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // ===== ASSESSMENTS =====
    match /assessments/{docId} {
      allow read: if ownsResource() || isAdmin();
      allow create: if ownsNewResource();
      allow update, delete: if ownsResource() || isAdmin();
    }

    // ===== BIOMETRIC DATA =====
    match /biometricData/{docId} {
      allow read: if ownsResource() || isAdmin();
      allow create: if ownsNewResource();
      allow update, delete: if ownsResource() || isAdmin();
    }

    // ===== JOURNALS =====
    match /journals/{docId} {
      allow read: if ownsResource() || isAdmin();
      allow create: if ownsNewResource();
      allow update, delete: if ownsResource() || isAdmin();
    }

    // ===== JOURNAL ENTRIES (legacy) =====
    match /journalEntries/{docId} {
      allow read: if ownsResource() || isAdmin();
      allow create: if ownsNewResource();
      allow update, delete: if ownsResource() || isAdmin();
    }

    // ===== MOOD LOGS =====
    match /moodLogs/{docId} {
      allow read: if ownsResource() || isAdmin();
      allow create: if ownsNewResource();
      allow update, delete: if ownsResource() || isAdmin();
    }

    // ===== MUSIC THERAPY LOGS =====
    match /musicTherapyLogs/{docId} {
      allow read: if ownsResource() || isAdmin();
      allow create: if ownsNewResource();
      allow update, delete: if ownsResource() || isAdmin();
    }

    // ===== HEALTH DATA =====
    match /healthData/{docId} {
      allow read: if ownsResource() || isAdmin();
      allow create: if ownsNewResource();
      allow update, delete: if ownsResource() || isAdmin();
    }

    // ===== HEALTH READINGS =====
    match /healthReadings/{docId} {
      allow read: if ownsResource() || isAdmin();
      allow create: if ownsNewResource();
      allow update, delete: if ownsResource() || isAdmin();
    }

    // ===== SESSIONS =====
    match /sessions/{docId} {
      allow read: if ownsResource() || isAdmin();
      allow create: if ownsNewResource();
      allow update, delete: if ownsResource() || isAdmin();
    }

    // ===== RECORDING HISTORY =====
    match /recordingHistory/{docId} {
      allow read: if ownsResource() || isAdmin();
      allow create: if ownsNewResource();
      allow update, delete: if ownsResource() || isAdmin();
    }

    // ===== INTERVENTION LOGS =====
    match /interventionLogs/{docId} {
      allow read: if ownsResource() || isAdmin();
      allow create: if ownsNewResource();
      allow update, delete: if ownsResource() || isAdmin();
    }

    // ===== INTERVENTIONS =====
    match /interventions/{docId} {
      allow read: if ownsResource() || isAdmin();
      allow create: if ownsNewResource();
      allow update, delete: if ownsResource() || isAdmin();
    }

    // ===== CRISIS LOGS =====
    match /crisisLogs/{docId} {
      allow read: if ownsResource() || isAdmin();
      allow create: if ownsNewResource();
      allow read, write, delete: if isAdmin();
    }

    // ===== SAFETY PLANS =====
    match /safetyPlans/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ===== EMERGENCY PLANS =====
    match /emergencyPlans/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ===== CHAT HISTORY =====
    match /chatHistory/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ===== USER SETTINGS =====
    match /userSettings/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ===== DAILY SUMMARY =====
    match /dailySummary/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ===== ANALYTICS SUMMARY =====
    match /analyticsSummary/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ===== ACADEMY PROGRESS =====
    match /academyProgress/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ===== GAMES PROGRESS =====
    match /gamesProgress/{gameId} {
      allow read: if ownsResource() || isAdmin();
      allow write: if ownsNewResource() || isAdmin();

      match /{sub=**} {
        allow read, write: if isAuthenticated();
      }
    }

    // ===== MEDITATION SESSIONS =====
    match /meditationSessions/{docId} {
      allow read: if ownsResource() || isAdmin();
      allow create: if ownsNewResource();
      allow update, delete: if ownsResource() || isAdmin();
    }

    // ===== SLEEP RECORDS =====
    match /sleepRecords/{docId} {
      allow read: if ownsResource() || isAdmin();
      allow create: if ownsNewResource();
      allow update, delete: if ownsResource() || isAdmin();
    }

    // ===== MINDFULNESS PROGRAMS =====
    match /mindfulnessPrograms/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===== SYSTEM (read-only for users) =====
    match /system/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===== API KEYS (Admin only) =====
    match /apiKeys/{docId} {
      allow read, write, delete: if isAdmin();
    }

    // ===== ADMIN ACTIVITY LOGS =====
    match /adminActivityLogs/{docId} {
      allow read, write: if isAdmin();
    }

    // ===== RESEARCH DATA =====
    match /researchData/{docId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
    }

    // ===== DENY ALL OTHER =====
    match /{document=**} {
      allow read, write, delete: if false;
    }
  }
}
